{
  "name": "dinsho-lounge-system",
  "version": "1.0.0",
  "description": "Dinsho Lounge Bill Management System",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "frontend": "cd frontend && npx live-server public --port=5500",
    "dev:full": "concurrently \"npm run dev\" \"npm run frontend\""
  },
  "keywords": [
    "restaurant",
    "billing",
    "management"
  ],
  "author": "Hamid Awol",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.0",
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "live-server": "^1.2.2",
    "nodemon": "^3.0.1"
  }
}
